def recorte_por_circulo(frames_dir, masks_dir, out_frames_dir, out_masks_dir):
    os.makedirs(out_frames_dir, exist_ok=True)
    os.makedirs(out_masks_dir, exist_ok=True)

    def detectar_bbox_endoscopio(img):
        if img is None:
            return None

        gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
        blur = cv2.GaussianBlur(gray, (11, 11), 0)

        thresh = cv2.adaptiveThreshold(
            blur, 255,
            cv2.ADAPTIVE_THRESH_GAUSSIAN_C,
            cv2.THRESH_BINARY,
            51, 2
        )
        thresh = 255 - thresh

        cnts, _ = cv2.findContours(thresh, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
        if len(cnts) == 0:
            return None

        c = max(cnts, key=cv2.contourArea)
        x, y, w, h = cv2.boundingRect(c)
        return x, y, x + w, y + h

    # ---------------------------------------------------
    # 1) PROCESAR FRAMES Y GUARDAR EL BBOX DE CADA UNO
    # ---------------------------------------------------
    bboxes = {}  # clave: nombre_base → bbox

    for fname in os.listdir(frames_dir):
        if not fname.lower().endswith((".jpg", ".jpeg", ".png")):
            continue

        frame_path = os.path.join(frames_dir, fname)
        img = cv2.imread(frame_path)

        if img is None:
            print(f"⚠ No se pudo leer frame: {frame_path}")
            continue

        bbox = detectar_bbox_endoscopio(img)
        if bbox is None:
            print(f"⚠ No se detectó círculo en frame: {fname}")
            continue

        x0, y0, x1, y1 = bbox
        rec = img[y0:y1, x0:x1]
        cv2.imwrite(os.path.join(out_frames_dir, fname), rec)

        # Guardamos el bbox usando el nombre base (sin extensión)
        base = os.path.splitext(fname)[0]
        bboxes[base] = bbox

        print(f"[FRAME RECORTADO] {fname}")

    # ---------------------------------------------------
    # 2) PROCESAR MÁSCARAS USANDO EL MISMO BBOX DEL FRAME
    # ---------------------------------------------------
    for fname in os.listdir(masks_dir):
        if not fname.lower().endswith((".jpg", ".jpeg", ".png")):
            continue

        base = os.path.splitext(fname)[0]  # nombre sin extensión

        if base not in bboxes:
            print(f"⚠ No hay bbox para la máscara: {fname} → NO EXISTE SU FRAME")
            continue

        mask_path = os.path.join(masks_dir, fname)
        mask = cv2.imread(mask_path, cv2.IMREAD_UNCHANGED)

        if mask is None:
            print(f"⚠ No se pudo leer máscara: {mask_path}")
            continue

        x0, y0, x1, y1 = bboxes[base]
        rec = mask[y0:y1, x0:x1]

        cv2.imwrite(os.path.join(out_masks_dir, fname), rec)
        print(f"[MÁSCARA RECORTADA] {fname}")




def recortar_frames_y_masks_izquierda(frames_dir, masks_dir, out_frames_dir, out_masks_dir,
                                      ancho=1376, alto=1080):
    """
    Recorre frames y máscaras, aplica el MISMO recorte por la izquierda
    (dejando la imagen en tamaño ancho x alto) y guarda los resultados
    en las carpetas de salida indicadas.
    """

    os.makedirs(out_frames_dir, exist_ok=True)
    os.makedirs(out_masks_dir, exist_ok=True)

    # --- 1. Recortar FRAMES ---
    for fname in os.listdir(frames_dir):
        if not fname.lower().endswith((".jpg", ".jpeg", ".png")):
            continue

        frame_path = os.path.join(frames_dir, fname)
        img = Image.open(frame_path)
        w, h = img.size

        if w < ancho or h < alto:
            print(f"⚠ Frame demasiado pequeño: {fname}")
            continue

        # Recorte por la izquierda
        left = 0
        upper = 0
        right = ancho
        lower = alto

        recorte = img.crop((left, upper, right, lower))
        recorte.save(os.path.join(out_frames_dir, fname))

        print(f"[FRAME RECORTADO] {fname}")

    # --- 2. Recortar MÁSCARAS ---
    for fname in os.listdir(masks_dir):
        if not fname.lower().endswith((".jpg", ".jpeg", ".png")):
            continue

        mask_path = os.path.join(masks_dir, fname)
        img = Image.open(mask_path)
        w, h = img.size

        if w < ancho or h < alto:
            print(f"⚠ Máscara demasiado pequeña: {fname}")
            continue

        # MISMO recorte por la izquierda
        left = 0
        upper = 0
        right = ancho
        lower = alto

        recorte = img.crop((left, upper, right, lower))
        recorte.save(os.path.join(out_masks_dir, fname))

        print(f"[MÁSCARA RECORTADA] {fname}")


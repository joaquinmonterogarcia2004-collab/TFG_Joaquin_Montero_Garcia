def procesar_dataset(carpeta_frames, carpeta_masks, out_frames, out_masks):
    for root, dirs, files in os.walk(carpeta_frames):
        for file in files:
            if not file.lower().endswith((".jpg", ".jpeg", ".png")):
                continue

            # Ruta completa del frame
            ruta_frame = os.path.join(root, file)

            # Subcarpeta relativa (nombre del vídeo)
            subruta = os.path.relpath(root, carpeta_frames)

            # Nombre base sin extensión
            nombre_base = os.path.splitext(file)[0]

            # Ruta de la máscara correspondiente
            ruta_mask = os.path.join(carpeta_masks, subruta, nombre_base + ".png")

            if not os.path.exists(ruta_mask):
                print("⚠ No se encontró máscara para:", ruta_frame)
                continue

            # Crear carpetas de salida
            out_frames_dir = os.path.join(out_frames, subruta)
            out_masks_dir = os.path.join(out_masks, subruta)
            os.makedirs(out_frames_dir, exist_ok=True)
            os.makedirs(out_masks_dir, exist_ok=True)

            # Leer imágenes
            img = cv2.imread(ruta_frame)
            mask = cv2.imread(ruta_mask, cv2.IMREAD_GRAYSCALE)

            if img is None or mask is None:
                print("⚠ Error leyendo:", ruta_frame)
                continue

            # Obtener bbox con tu método nuevo
            bbox = obtener_bbox(img)
            if bbox is None:
                print("⚠ No bbox:", ruta_frame)
                continue

            # Recortar
            img_rec, mask_rec = recortar_img_y_mask(img, mask, bbox)

            # Guardar frame en JPG
            out_frame_path = os.path.join(out_frames_dir, nombre_base + ".jpg")
            cv2.imwrite(out_frame_path, img_rec, [int(cv2.IMWRITE_JPEG_QUALITY), 95])

            # Guardar máscara en PNG
            out_mask_path = os.path.join(out_masks_dir, nombre_base + ".png")
            cv2.imwrite(out_mask_path, mask_rec)

            print("✔ Procesado:", os.path.join(subruta, nombre_base))
